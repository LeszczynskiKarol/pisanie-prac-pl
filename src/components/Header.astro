---
// Header — wspólny navbar dla wszystkich stron. Mobile menu na vanilla JS.
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./Icon.astro";

const nav = [
  { href: "/#typy-prac", label: "Typy prac" },
  { href: "/jak-pomagam/", label: "Jak pomagam" },
  { href: "/legalnosc/", label: "Legalność" },
];
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <Logo />

    <nav aria-label="Główne" class="hidden items-center gap-6 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-[0.9375rem] text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]"
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle />
      <a
        href="/kontakt/"
        class="inline-flex items-center gap-1.5 rounded-md bg-[var(--color-accent)] px-4 py-2 text-sm font-medium text-[var(--color-accent-fg)] no-underline transition-colors hover:bg-[var(--color-accent-hover)]"
      >
        Bezpłatna wycena
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        class="needs-js inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text)]"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Otwórz menu"
      >
        <Icon name="menu" class="h-5 w-5" data-icon="open" />
        <Icon name="x" class="hidden h-5 w-5" data-icon="close" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] bg-[var(--color-bg)] md:hidden">
    <nav aria-label="Menu mobilne" class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-4 sm:px-6">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-md px-3 py-2.5 text-[0.9375rem] font-medium text-[var(--color-text)] no-underline hover:bg-[var(--color-bg-subtle)]"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/kontakt/"
        class="mt-2 inline-flex items-center justify-center gap-1.5 rounded-md bg-[var(--color-accent)] px-4 py-2.5 text-sm font-medium text-[var(--color-accent-fg)] no-underline"
      >
        Bezpłatna wycena
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("mobile-menu-btn");
    var menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;
    btn.addEventListener("click", function () {
      var open = menu.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute("aria-label", open ? "Zamknij menu" : "Otwórz menu");
      btn.querySelector('[data-icon="open"]').classList.toggle("hidden", open);
      btn.querySelector('[data-icon="close"]').classList.toggle("hidden", !open);
    });
  })();
</script>
